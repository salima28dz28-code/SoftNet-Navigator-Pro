<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:background="@android:color/transparent"
	android:overScrollMode="never">

	<LinearLayout
		android:id="@+id/banner_container"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:orientation="vertical"
		android:paddingBottom="@dimen/content_padding">

		<View
			android:layout_width="36dp"
			android:layout_height="4dp"
			android:layout_gravity="center_horizontal"
			android:layout_marginTop="@dimen/content_padding_half"
			android:layout_marginBottom="@dimen/content_padding_half"
			android:background="@drawable/rectangle_rounded"
			android:backgroundTint="?attr/secondary_icon_color" />

		<FrameLayout
			android:layout_width="match_parent"
			android:layout_height="@dimen/toolbar_height"
			android:paddingLeft="@dimen/content_padding_half"
			android:paddingRight="@dimen/content_padding_half">

			<FrameLayout
				android:id="@+id/close_button"
				android:layout_width="@dimen/acceptable_touch_radius"
				android:layout_height="@dimen/acceptable_touch_radius"
				android:layout_gravity="start|center_vertical"
				android:background="?attr/selectableItemBackground">

				<FrameLayout
					android:layout_width="32dp"
					android:layout_height="32dp"
					android:layout_gravity="center"
					android:background="@drawable/bg_circle" />

				<androidx.appcompat.widget.AppCompatImageView
					android:layout_width="24dp"
					android:layout_height="24dp"
					android:layout_gravity="center"
					android:contentDescription="@string/shared_string_close"
					android:tint="?attr/default_icon_color"
					app:srcCompat="@drawable/ic_action_close_rounded" />

			</FrameLayout>

			<net.osmand.plus.widgets.TextViewEx
				android:id="@+id/restore_button"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_gravity="end|center_vertical"
				android:gravity="center"
				android:layout_marginEnd="@dimen/content_padding_small"
				android:paddingHorizontal="@dimen/content_padding_small"
				android:paddingVertical="@dimen/content_padding_half"
				android:text="@string/shared_string_restore"
				android:textColor="?attr/active_color_basic"
				android:textSize="@dimen/default_desc_text_size"
				app:typefaceWeight="medium" />

		</FrameLayout>

		<LinearLayout
			android:id="@+id/plan_content"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:layout_marginStart="@dimen/content_padding_small"
			android:layout_marginEnd="@dimen/content_padding_small">

			<LinearLayout
				android:id="@+id/header"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="vertical"
				android:paddingLeft="@dimen/content_padding_small"
				android:paddingRight="@dimen/content_padding_small">

				<androidx.appcompat.widget.AppCompatImageView
					android:id="@+id/header_icon"
					android:layout_width="@dimen/banner_main_icon_size"
					android:layout_height="@dimen/banner_main_icon_size"
					android:layout_gravity="center"
					app:srcCompat="@drawable/ic_action_cloud_upload_colored" />

				<net.osmand.plus.widgets.TextViewEx
					android:id="@+id/header_icon_title"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_gravity="center_horizontal"
					android:layout_marginTop="@dimen/content_padding"
					android:textColor="?android:textColorPrimary"
					android:textSize="@dimen/big_header_text_size"
					app:typefaceWeight="medium"
					tools:text="@string/osmand_pro" />

			</LinearLayout>

			<LinearLayout
				android:id="@+id/primary_description_container"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="@dimen/content_padding_small"
				android:gravity="center_horizontal"
				android:orientation="vertical"
				android:paddingLeft="@dimen/content_padding_small"
				android:paddingRight="@dimen/content_padding_small"
				>

				<net.osmand.plus.widgets.TextViewEx
					android:id="@+id/primary_description"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:gravity="center_horizontal"
					android:textColor="?android:textColorSecondary"
					android:textSize="@dimen/default_list_text_size"
					tools:text="Get OsmAnd Cloud to store all OsmAnd data online." />
			</LinearLayout>

			<net.osmand.plus.widgets.FlowLayout
				android:id="@+id/list_container"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="@dimen/content_padding_small_double"
				android:layout_marginStart="@dimen/content_padding_small"
				android:layout_marginEnd="@dimen/content_padding_small"
				app:horizontalItemsSpacing="@dimen/content_padding_half"
				app:verticalItemsSpacing="@dimen/content_padding_half" />

			<LinearLayout
				android:id="@+id/purchase_buttons"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="@dimen/content_padding_small_double"
				android:layout_marginLeft="@dimen/content_padding_small"
				android:layout_marginRight="@dimen/content_padding_small"
				android:orientation="vertical">

				<LinearLayout
					android:id="@+id/price_block"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginBottom="@dimen/content_padding"
					android:background="?attr/stroked_btn_contour"
					android:orientation="vertical" />

				<include
					android:id="@+id/apply_button"
					layout="@layout/purchase_dialog_btn_apply" />

			</LinearLayout>

			<net.osmand.plus.widgets.TextViewEx
				android:id="@+id/cancel_description"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_gravity="center_horizontal"
				android:letterSpacing="@dimen/description_letter_spacing"
				android:lineSpacingMultiplier="@dimen/info_description_line_spacing_multiplier"
				android:paddingLeft="@dimen/content_padding"
				android:paddingTop="@dimen/content_padding_small_half"
				android:paddingRight="@dimen/content_padding"
				android:paddingBottom="@dimen/content_padding_half"
				android:text="@string/cancel_anytime_in_gplay"
				android:textColor="?android:attr/textColorSecondary"
				android:textSize="@dimen/default_desc_text_size"
				android:textStyle="normal" />

		</LinearLayout>

		<LinearLayout
			android:id="@+id/message_content"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:paddingLeft="@dimen/content_padding"
			android:paddingRight="@dimen/content_padding"
			android:visibility="gone">

			<androidx.appcompat.widget.AppCompatImageView
				android:id="@+id/icon"
				android:layout_width="@dimen/big_icon_size"
				android:layout_height="@dimen/big_icon_size"
				android:layout_gravity="center_horizontal"
				tools:srcCompat="@drawable/ic_action_osmand_pro_logo_colored" />

			<net.osmand.plus.widgets.TextViewEx
				android:id="@+id/title"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="@dimen/content_padding"
				android:gravity="center"
				android:textColor="?android:textColorPrimary"
				android:textSize="@dimen/big_header_text_size"
				app:typefaceWeight="medium"
				tools:text="OsmAnd Pro" />

			<net.osmand.plus.widgets.TextViewEx
				android:id="@+id/description"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="@dimen/content_padding_half"
				android:gravity="center"
				android:lineSpacingMultiplier="@dimen/info_description_line_spacing_multiplier"
				android:textColor="?android:textColorSecondary"
				android:textSize="@dimen/default_list_text_size"
				tools:text="Get access to all premium OsmAnd features." />

			<net.osmand.plus.widgets.TextViewEx
				android:id="@+id/action_button"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="@dimen/content_padding"
				android:background="?attr/dlg_btn_primary"
				android:gravity="center"
				android:minHeight="@dimen/dialog_button_height"
				android:paddingLeft="@dimen/content_padding"
				android:paddingTop="@dimen/content_padding_half"
				android:paddingRight="@dimen/content_padding"
				android:paddingBottom="@dimen/content_padding_half"
				android:textColor="?attr/dlg_btn_primary_text"
				android:textSize="@dimen/text_button_text_size"
				app:typefaceWeight="medium"
				tools:text="Learn more" />

		</LinearLayout>

	</LinearLayout>

</androidx.core.widget.NestedScrollView>
