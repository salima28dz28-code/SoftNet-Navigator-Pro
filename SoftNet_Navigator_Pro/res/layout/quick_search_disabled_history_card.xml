<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:id="@+id/disabled_history_card"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:background="?attr/activity_background_color"
	android:orientation="vertical"
	android:paddingBottom="@dimen/content_padding_half">

	<LinearLayout
		android:id="@+id/card_container"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:background="@drawable/bg_list_card_bottom_round"
		android:orientation="vertical">

		<include
			android:id="@+id/top_divider"
			layout="@layout/simple_divider_item" />

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="horizontal"
			android:paddingStart="@dimen/content_padding"
			android:paddingTop="@dimen/content_padding"
			android:paddingEnd="@dimen/content_padding"
			android:paddingBottom="@dimen/content_padding">

			<androidx.appcompat.widget.AppCompatImageView
				android:layout_width="@dimen/standard_icon_size"
				android:layout_height="@dimen/standard_icon_size"
				android:layout_marginEnd="@dimen/content_padding"
				app:srcCompat="@drawable/ic_action_history_disabled"
				app:tint="?attr/default_icon_color" />

			<LinearLayout
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:layout_marginStart="@dimen/content_padding"
				android:orientation="vertical">

				<net.osmand.plus.widgets.TextViewEx
					android:id="@+id/title"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="@string/history_is_turned_off"
					android:textColor="?android:textColorPrimary"
					android:textSize="@dimen/default_list_text_size"
					app:typefaceWeight="medium" />

				<net.osmand.plus.widgets.TextViewEx
					android:id="@+id/description"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:layout_marginTop="@dimen/content_padding_half"
					android:layout_marginBottom="@dimen/content_padding_minimal"
					android:text="@string/search_and_navigation_history_disabled_descr"
					android:textColor="?android:textColorSecondary"
					android:textSize="@dimen/default_desc_text_size"
					app:lineHeight="@dimen/default_desc_line_height" />

				<FrameLayout
					android:id="@+id/settings_button_container"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginTop="@dimen/content_padding_half"
					android:background="?attr/btn_history_disabled_card_bg">

					<net.osmand.plus.widgets.TextViewEx
						android:id="@+id/settings_button"
						android:layout_width="wrap_content"
						android:layout_height="@dimen/route_info_buttons_height"
						android:background="?attr/dlg_btn_ripple"
						android:ellipsize="end"
						android:gravity="center"
						android:maxLines="1"
						android:paddingStart="@dimen/content_padding_small"
						android:paddingEnd="@dimen/content_padding_small"
						android:text="@string/open_history_settings"
						android:textColor="?attr/active_color_basic"
						android:textSize="@dimen/text_button_text_size"
						app:typefaceWeight="medium"
						tools:ignore="UnusedAttribute" />

				</FrameLayout>

			</LinearLayout>

		</LinearLayout>

	</LinearLayout>

</LinearLayout>